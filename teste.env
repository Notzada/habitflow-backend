# ============================================
# HABITFLOW - Variáveis de Ambiente
# Copie este arquivo como .env e preencha
# NÃO suba o .env para o GitHub!
# ============================================

# 1. Telegram — obtenha em t.me/BotFather
TELEGRAM_TOKEN=seu_token_aqui

# 2. Supabase — em app.supabase.com > Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sua_anon_key_aqui

# 3. Google Gemini — em aistudio.google.com/apikey (grátis)
GEMINI_KEY=sua_gemini_key_aqui

# 4. URL do seu backend no Render (preencha após deploy)
WEBHOOK_URL=https://seu-app.onrender.com

# Porta (o Render define automaticamente)
PORT=3000
